# GME Trading System — Environment Variables Template
# Copy to .env and fill in values. Never commit .env.

# LLM API Keys (used as fallbacks for local Gemma)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Market Data
FINNHUB_API_KEY=your-finnhub-key-here

# Supabase (dashboard sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# Notifications
DISCORD_BOT_TOKEN=your-discord-bot-token-here
