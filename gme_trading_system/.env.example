# Copy this file to .env and fill in your values

# LLM providers
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Broker (IBKR via ib_insync)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Public broadcast surface (channel ID, e.g. -100123...). Read-only, alerts fan out here.
TELEGRAM_CHAT_ID=
# Owner DM (user ID). Receives the same alerts and is the only chat allowed to run owner-only commands.
TELEGRAM_OWNER_CHAT_ID=

# Supabase (cloud sync + Edge Functions)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=

# News / data
FINNHUB_API_KEY=
NEWSAPI_KEY=

# Twitter / X (optional — falls back to Supabase Edge Function)
X_BEARER_TOKEN=

# SEC EDGAR (no key needed — set a user-agent string)
SEC_USER_AGENT=YourAppName your@email.com
